     <script>
$('.up').on('click', function () {
    $('h1,h2,h3,h4,h5,h6').animate({'font-size': '+=5'});
    $('h1,h2,h3,h4,h5,h6').animate({'line-height': '+=3'});
    $('li').animate({'font-size': '+=3'});
    $('p').animate({'font-size': '+=3'});
   

});

$('.original').on('click', function () {
    window.location.reload();
});


$('.down').on('click', function () {
    $('h1,h2,h3,h4,h5,h6').animate({'font-size': '-=5'});
    $('h1,h2,h3,h4,h5,h6').animate({'line-height': '-=3'});
    $('li').animate({'font-size': '-=3'});
    $('p').animate({'font-size': '-=3'});
});
</script>
<script>
                                $('.ticker').on('click', function () {
                                    if ($(this).next('div').hasClass('active show')) {
                                        $(this).next('div').removeClass('active show');
                                    } else {
                                        $('.ticker').next('div').removeClass('active show');
                                        $(this).next('div').addClass('active show');
                                    }
                                    $('html,body').animate({scrollTop: $(this).offset().top - 80});
                                });
                            </script>

  </body>
